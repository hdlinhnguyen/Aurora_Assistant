flowchart TD
    A[Khởi tạo Quiz Session] --> B[Load Quiz Data]

    B --> B1[Nội dung câu hỏi]
    B --> B2[Hình ảnh hoặc tài nguyên]
    B --> B3[Metadata câu hỏi]
    B --> B4[Quy tắc làm bài]

    B1 --> C[Hiển thị câu hỏi]
    B2 --> C
    B3 --> C
    B4 --> C

    C --> D[Học sinh nhập câu trả lời]
    D --> E[Submit Student Answer]

    E --> F[Lưu câu trả lời trên hệ thống]
    F --> G{Còn câu hỏi?}

    G -- Có --> C
    G -- Không --> H[Kết thúc Quiz Session]

    H --> I[Đóng phiên làm bài]
    I --> J[Chuyển kết quả sang Answer Evaluation]

    classDef default fill:#1f1f1f,stroke:#a8a8a8,color:#f3f3f3,stroke-width:1px
    linkStyle default stroke:#c8c8c8,stroke-width:1px
