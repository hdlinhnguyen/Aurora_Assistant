flowchart TD
    A[Question Result] --> B[Feedback Engine]
    C[Load Question Data] --> B

    B --> D{Giáo viên đã cung cấp<br/>lời giải hoặc barem?}

    D -- Có lời giải --> E[Hiển thị lời giải<br/>của giáo viên]
    D -- Có barem --> F[Hiển thị barem<br/>và các bước đạt điểm]
    D -- Không có --> G{LLM khả dụng?}

    G -- Có --> H[LLM Explanation Generator]
    G -- Không --> I[Hiển thị đáp án đúng<br/>và thông báo chưa có lời giải]

    H --> H1[Nhận câu hỏi]
    H --> H2[Nhận đáp án đúng]
    H --> H3[Nhận câu trả lời học sinh]
    H --> H4[Nhận Topic Tag]
    H --> H5[Nhận kiến thức liên quan<br/>từ Knowledge Graph]

    H1 --> J[Grounded Explanation]
    H2 --> J
    H3 --> J
    H4 --> J
    H5 --> J

    J --> J1[Giải thích vì sao sai]
    J --> J2[Trình bày cách giải đúng]
    J --> J3[Nhắc lại kiến thức nền]
    J --> J4[Gợi ý topic cần ôn]

    E --> K[Student Feedback]
    F --> K
    I --> K
    J1 --> K
    J2 --> K
    J3 --> K
    J4 --> K

    K --> L[Học sinh xem kết quả<br/>và lời giải]

    classDef default fill:#1f1f1f,stroke:#a8a8a8,color:#f3f3f3,stroke-width:1px
    linkStyle default stroke:#c8c8c8,stroke-width:1px
