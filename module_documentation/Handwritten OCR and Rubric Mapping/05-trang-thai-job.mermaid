%%{init: {"theme": "base", "themeVariables": {"background": "#1f1f1f", "primaryColor": "#1f1f1f", "primaryTextColor": "#f3f3f3", "primaryBorderColor": "#a8a8a8", "secondaryColor": "#1f1f1f", "tertiaryColor": "#1f1f1f", "lineColor": "#c8c8c8", "edgeLabelBackground": "#1f1f1f", "fontFamily": "Georgia, 'Times New Roman', serif"}}}%%
flowchart LR
    A([Tạo job]) --> B[queued]
    B --> C[processing]

    C -->|Thành công| D[completed]
    C -->|Lỗi tạm thời| E[retrying]
    E -->|Còn lượt retry| B
    E -->|Hết lượt retry| F[failed]

    B -->|Giảng viên chuyển manual| G[cancelled]
    C -->|Giảng viên chuyển manual| G
    E -->|Giảng viên chuyển manual| G

    F --> H{Loại job}
    H -->|OCR Job| I[Full manual<br/>ảnh gốc + barem]
    H -->|Mapping Job| J[Partial fallback<br/>OCR blocks + barem]

    D --> K{Loại job}
    K -->|OCR Job| L[Tạo Mapping Job]
    K -->|Mapping Job| M[Tạo Draft Rubric Mapping]

    I --> N[awaiting_review]
    J --> N
    M --> N
    G --> N
    N --> O[approved]

    classDef default fill:#1f1f1f,stroke:#a8a8a8,color:#f3f3f3,stroke-width:1px
    classDef decision fill:#2a2a2a,stroke:#e0b76a,color:#fff2cc,stroke-width:1.5px
    classDef terminal fill:#1f1f1f,stroke:#76b7b2,color:#dff7f5,stroke-width:1.5px
    class H,K decision
    class D,F,G,O terminal
    linkStyle default stroke:#c8c8c8,stroke-width:1px
